@page "/settings"
@using CptcYourself.Client.Models
@inject CryptoStorageService Crypto
@inject AppStateService State
@inject NavigationManager Nav

<PageTitle>Settings – CPTC Yourself</PageTitle>

<div class="settings-page">
    <h2 class="page-title">⚙️ Settings</h2>
    <p class="subtitle">Your credentials are encrypted with AES-256-GCM using a password you choose and stored only in this browser's IndexedDB — they never leave your device.</p>

    @if (_saved)
    {
        <div class="alert-success">✅ Settings saved and encrypted successfully.</div>
    }
    @if (_error is not null)
    {
        <div class="alert-error">@_error</div>
    }

    <div class="card">
        <label class="field-label">API Provider</label>
        <div class="chip-list" style="margin-bottom:1rem">
            <button class="chip @(_provider == ApiProvider.AiStudio ? "active" : "")"
                    @onclick='() => _provider = ApiProvider.AiStudio'>
                Google AI Studio
            </button>
            <button class="chip @(_provider == ApiProvider.VertexAi ? "active" : "")"
                    @onclick='() => _provider = ApiProvider.VertexAi'>
                Vertex AI
            </button>
        </div>

        @if (_provider == ApiProvider.AiStudio)
        {
            <label class="field-label">Google AI Studio API Key</label>
            <input class="field-input"
                   type="password"
                   placeholder="AIza…"
                   @bind="_secret"
                   @bind:event="oninput" />
        }
        else
        {
            <label class="field-label">Service Account Key JSON</label>
            <textarea class="field-input"
                      rows="6"
                      placeholder='{ "type": "service_account", "project_id": "...", "private_key": "...", ... }'
                      @bind="_secret"
                      @bind:event="oninput" />
            <p style="font-size:0.8rem;color:var(--text-muted,#888);margin-top:0.25rem">
                Download a service account key JSON from the GCP Console and paste it here.
                The project ID is read automatically from the JSON. Credentials are encrypted before storage.
            </p>
        }

        <label class="field-label">Encryption Password</label>
        <input class="field-input"
               type="password"
               placeholder="Choose a strong password"
               @bind="_password"
               @bind:event="oninput" />

        <label class="field-label">Confirm Password</label>
        <input class="field-input"
               type="password"
               placeholder="Repeat password"
               @bind="_confirmPassword"
               @bind:event="oninput" />

        <button class="btn-primary" @onclick="SaveAsync" disabled="@_busy">
            @(_busy ? "Saving…" : "Save & Encrypt")
        </button>
    </div>

    @if (_hasExisting)
    {
        <div class="card danger-zone">
            <h3>Danger Zone</h3>
            <p>Remove the stored credentials from this browser entirely.</p>
            <button class="btn-danger" @onclick="ClearAsync" disabled="@_busy">Forget Credentials</button>
        </div>
    }

    <button class="btn-ghost" @onclick='() => Nav.NavigateTo("/")'>← Back</button>
</div>

@code {
    private ApiProvider _provider        = ApiProvider.AiStudio;
    private string _secret               = string.Empty;
    private string _password             = string.Empty;
    private string _confirmPassword      = string.Empty;
    private bool   _busy;
    private bool   _saved;
    private bool   _hasExisting;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var existing = await Crypto.LoadSettingsAsync();
        if (existing is not null)
        {
            _hasExisting = true;
            _provider    = existing.Provider;
        }
    }

    private async Task SaveAsync()
    {
        _error = null;
        _saved = false;

        if (string.IsNullOrWhiteSpace(_secret))    { _error = _provider == ApiProvider.AiStudio ? "API key is required." : "Service account JSON is required."; return; }
        if (_password.Length < 8)                  { _error = "Password must be at least 8 characters."; return; }
        if (_password != _confirmPassword)         { _error = "Passwords do not match."; return; }

        _busy = true;
        try
        {
            await Crypto.SaveApiKeyAsync(_secret, _password, _provider);
            _saved           = true;
            _hasExisting     = true;
            _secret          = string.Empty;
            _password        = string.Empty;
            _confirmPassword = string.Empty;
        }
        catch (Exception ex)
        {
            _error = $"Failed to save: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ClearAsync()
    {
        _busy = true;
        try
        {
            await Crypto.ClearSettingsAsync();
            State.Lock();
            _hasExisting = false;
        }
        finally
        {
            _busy = false;
        }
    }
}
